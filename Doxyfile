# Doxyfile for Zipper — C++ Tensor Expression Template Library
# Doxygen 1.13.x

#---------------------------------------------------------------------------
# Project
#---------------------------------------------------------------------------
PROJECT_NAME           = "Zipper"
PROJECT_BRIEF          = "C++ tensor expression template library"
PROJECT_NUMBER         =
OUTPUT_DIRECTORY       = docs

#---------------------------------------------------------------------------
# Input
#---------------------------------------------------------------------------
INPUT                  = include/zipper
FILE_PATTERNS          = *.hpp *.hxx *.md
RECURSIVE              = YES
EXCLUDE_PATTERNS       = */subprojects/* */build*/* */tests/*

# Treat .md files as documentation pages
USE_MDFILE_AS_MAINPAGE =

#---------------------------------------------------------------------------
# Extraction
#---------------------------------------------------------------------------
EXTRACT_ALL            = NO
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = YES
EXTRACT_ANON_NSPACES   = NO

# Existing comments use implicit brief (first sentence), not @brief
JAVADOC_AUTOBRIEF      = YES
MULTILINE_CPP_IS_BRIEF = NO

# Show all members, including inherited
INLINE_INHERITED_MEMB  = YES

#---------------------------------------------------------------------------
# Source browsing
#---------------------------------------------------------------------------
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
STRIP_CODE_COMMENTS    = YES
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES

#---------------------------------------------------------------------------
# Preprocessing
#---------------------------------------------------------------------------
ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = YES
EXPAND_ONLY_PREDEF     = NO
PREDEFINED             = __cplusplus=202602L \
                         ZIPPER_FMT_OVERRIDES_DISABLED= \
                         ZIPPER_DONT_USE_ALIAS_CTAD=

#---------------------------------------------------------------------------
# Output — HTML only
#---------------------------------------------------------------------------
GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_COLORSTYLE        = LIGHT
HTML_DYNAMIC_SECTIONS  = YES
HTML_INDEX_NUM_ENTRIES = 100
SEARCHENGINE           = YES
GENERATE_TREEVIEW      = YES

GENERATE_LATEX         = NO
GENERATE_RTF           = NO
GENERATE_MAN           = NO
GENERATE_XML           = NO

#---------------------------------------------------------------------------
# Diagrams
#---------------------------------------------------------------------------
HAVE_DOT               = NO
COLLABORATION_GRAPH    = NO
INCLUDE_GRAPH          = NO
INCLUDED_BY_GRAPH      = NO

# Disable LaTeX formula rendering (avoids latex dependency errors)
FORMULA_FONTSIZE       = 10
FORMULA_TRANSPARENT    = YES

#---------------------------------------------------------------------------
# Warnings
#---------------------------------------------------------------------------
QUIET                  = NO
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = NO
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = NO
WARN_FORMAT            = "$file:$line: $text"

#---------------------------------------------------------------------------
# Namespace / class sorting
#---------------------------------------------------------------------------
SORT_MEMBER_DOCS       = YES
SORT_BRIEF_DOCS        = NO
SORT_GROUP_NAMES       = YES
